# development (default) or production — production enforces JWT_SECRET and
# EVIDENCE_ENCRYPTION_KEY are actually set at boot instead of failing lazily later.
NODE_ENV=development
PORT=3000
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=8h
DB_PATH=./data/incident-case-mgmt.sqlite
CORS_ORIGIN=http://localhost:5173

# Generate with: openssl rand -base64 32
# Also used to encrypt inline case-narrative images (see CASE_IMAGE_STORAGE_DIR)
# and encrypted-at-rest MFA TOTP secrets.
EVIDENCE_ENCRYPTION_KEY=
EVIDENCE_STORAGE_DIR=./data/evidence
CASE_IMAGE_STORAGE_DIR=./data/case-images

# Optional — Google Sign-In. Leave both unset to disable the feature entirely
# (POST /auth/google responds 503 rather than the app refusing to boot; unlike
# JWT_SECRET/EVIDENCE_ENCRYPTION_KEY this isn't required for core functionality).
#
# GOOGLE_CLIENT_ID: OAuth 2.0 Client ID (type "Web application") from
# https://console.cloud.google.com/apis/credentials — add both
# http://localhost:5173 (dev) and your real origin as an Authorized JavaScript
# origin. Safe to also expose to the frontend (see frontend/.env.example);
# it identifies the app, not a secret.
GOOGLE_CLIENT_ID=
# GOOGLE_SSO_ALLOWED_DOMAIN: comma-separated email domain(s) (e.g.
# "yourcompany.com" for a Google Workspace org, or "gmail.com" to allow any
# personal Gmail account) allowed to auto-provision a brand-new account on
# first Google sign-in. Auto-provisioned accounts get Analyst L1 with no
# team — an Admin still has to assign a real role/team before they can do
# much. Existing accounts (created via seed or, later, an admin UI) can
# always sign in with a matching Google email regardless of this setting —
# the domain check only gates creating new accounts unattended. Checked
# against the verified email's own domain suffix, not Google's "hd" claim,
# since personal Gmail accounts never carry an "hd" claim at all.
GOOGLE_SSO_ALLOWED_DOMAIN=
