# development (default) or production — production enforces JWT_SECRET and
# EVIDENCE_ENCRYPTION_KEY are actually set at boot instead of failing lazily later.
NODE_ENV=development
PORT=3000
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=8h
DB_PATH=./data/incident-case-mgmt.sqlite
CORS_ORIGIN=http://localhost:5173

# Generate with: openssl rand -base64 32
# Also used to encrypt inline case-narrative images (see CASE_IMAGE_STORAGE_DIR).
EVIDENCE_ENCRYPTION_KEY=
EVIDENCE_STORAGE_DIR=./data/evidence
CASE_IMAGE_STORAGE_DIR=./data/case-images
